pipeline {
  agent {label 'ns07-kube'}
 
  stages {
    
    stage('Checkout') {
      steps {
        git branch: 'main',
                    credentialsId: 'ns07-github-cred',
                    url: 'git@github.com:pgaws/k8slab.git'                    
      }
    }
      stage('Check the docker cli') {
      steps {
        sh "docker --version"
        sh "docker ps -a"
      }
    }
    stage('Build Docker Image') {
      steps {
        sh '''
          docker build -t gonurup/py-may26:$BUILD_NUMBER app
        '''
      }
    }
        stage('Push Docker Image') {
        steps {
            withCredentials([
            usernamePassword(
                credentialsId: 'ns07-docker-cred',
                usernameVariable: 'DOCKERHUB_USER',
                passwordVariable: 'DOCKERHUB_PASS'
            )
            ]) {
            sh '''
                echo "$DOCKERHUB_PASS" | docker login -u "$DOCKERHUB_USER" --password-stdin
                docker push gonurup/py-may26:$BUILD_NUMBER
                docker logout
            '''
            }
        }
    }
    stage('Check on Kubernetes') {
      steps {
        sh '''
          export KUBECONFIG=$HOME/k8s-3-node.conf
          kubectl get pods
          kubectl get svc
          kubectl get deployments
        '''
      }
    }
    stage('Deploy with Helm') {
        steps {
            sh '''
            export KUBECONFIG=$HOME/k8s-3-node.conf
            helm uninstall py-redis-app --namespace ns07 || true
            kubectl delete svc/redis-service svc/py-service deployment/redis-deploy deployment/py-deploy configmap/py-config --ignore-not-found
            helm upgrade --install py-redis-app ./helm-py-redis \
              --namespace ns07 \
              --set pythonApp.image.repository=sivakumarippili/py-may26 \
              --set pythonApp.image.tag=$BUILD_NUMBER \
              --set pythonApp.service.type=ClusterIP \
              --atomic --cleanup-on-fail
            helm status py-redis-app --namespace ns07
            kubectl rollout status deployment/py-deploy --namespace ns07
        '''
        }
    }
    stage('Application Health Check') {
      steps {
        sh '''
          sleep 10
          curl http://172.31.15.50:30107
        '''
      }
    }

  }
}